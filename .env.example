# ============================================================================
# FanTribe - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local
#
# IMPORTANT: Never commit .env or .env.local files!
# ============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# CONVEX
# ──────────────────────────────────────────────────────────────────────────────
CONVEX_DEPLOYMENT=dev:your-deployment-slug
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-slug.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment-slug.convex.site

# ──────────────────────────────────────────────────────────────────────────────
# CLERK (Authentication)
# ──────────────────────────────────────────────────────────────────────────────
# Server-side (read by Clerk SDK via process.env)
CLERK_SECRET_KEY=sk_test_...

# Client-side
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://your-instance.clerk.accounts.dev

# Optional - defaults defined in code
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up

# Note: CLERK_WEBHOOK_SECRET is set in Convex dashboard only (webhook handled by Convex HTTP Action)

# ──────────────────────────────────────────────────────────────────────────────
# STRIPE (Card payments)
# ──────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...

# Note: STRIPE_WEBHOOK_SECRET is set in Convex dashboard only (webhook handled by Convex HTTP Action)

# ──────────────────────────────────────────────────────────────────────────────
# CINETPAY (Mobile money: OM/MOMO)
# ──────────────────────────────────────────────────────────────────────────────
# Client-side (used by lib/services/cinetpay.ts to initialize payments)
NEXT_PUBLIC_CINETPAY_API_KEY=
NEXT_PUBLIC_CINETPAY_SITE_ID=

# Note: CINETPAY_SECRET_KEY, CINETPAY_API_KEY, CINETPAY_SITE_ID are also set in
# Convex dashboard for webhook verification. The NEXT_PUBLIC_ variants above are
# needed by the client to initiate payments.

# Optional - defaults to Convex site URLs derived from NEXT_PUBLIC_CONVEX_URL
# Only override if you need to use a different webhook receiver (e.g., ngrok for debugging)
# NEXT_PUBLIC_CINETPAY_NOTIFY_URL=https://your-deployment.convex.site/cinetpay
# NEXT_PUBLIC_CINETPAY_RETURN_URL=https://your-deployment.convex.site/cinetpay-return

# ──────────────────────────────────────────────────────────────────────────────
# BUNNY CDN (Media storage & video streaming)
# ──────────────────────────────────────────────────────────────────────────────
# All Bunny secrets are managed in the Convex dashboard only.
# Set the following in your Convex environment variables:
#   BUNNY_STORAGE_ZONE, BUNNY_STORAGE_PASSWORD, BUNNY_CDN_HOSTNAME,
#   BUNNY_STREAM_LIBRARY_ID, BUNNY_STREAM_API_KEY, BUNNY_URL_TOKEN_KEY

# ──────────────────────────────────────────────────────────────────────────────
# RESEND (Transactional emails)
# ──────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ──────────────────────────────────────────────────────────────────────────────
# PAYMENT TEST MODE
# ──────────────────────────────────────────────────────────────────────────────
# Set to "true" to simulate payments without calling Stripe/CinetPay
# NEXT_PUBLIC_PAYMENT_TEST_MODE=true
# Set to "true" to force payment failure in test mode
# NEXT_PUBLIC_PAYMENT_TEST_FORCE_FAIL=true

# ──────────────────────────────────────────────────────────────────────────────
# SENTRY (Error monitoring - used by build plugin)
# ──────────────────────────────────────────────────────────────────────────────
SENTRY_AUTH_TOKEN=sntrys_...

# ──────────────────────────────────────────────────────────────────────────────
# E2E TESTS (local-only — preserved by `bun run env:sync`, NOT on Vercel)
# ──────────────────────────────────────────────────────────────────────────────
E2E_CLERK_USER_USERNAME=
E2E_CLERK_USER_PASSWORD=
E2E_CLERK_CREATOR_USERNAME=
E2E_CLERK_CREATOR_PASSWORD=
E2E_CLERK_ADMIN_USERNAME=
E2E_CLERK_ADMIN_PASSWORD=
E2E_CREATOR_USERNAME=

# ──────────────────────────────────────────────────────────────────────────────
# Sync flow
# ──────────────────────────────────────────────────────────────────────────────
# First time on a new machine:
#   1) bun install
#   2) vercel link        (links to rinkhimeras-projects/onlyscam)
#   3) bun run env:sync   (pulls Vercel "development" vars into .env.local)
#   4) Fill the E2E_* vars manually (kept across future syncs)
#
# On subsequent machines / after env changes on the dashboard:
#   bun run env:sync           # refreshes .env.local from Vercel "development"
#   bun run env:sync production  # to test against prod env vars
#   bun run env:diff           # shows missing keys on either side
