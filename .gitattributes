# Normalize line endings to LF in the repo, regardless of OS or core.autocrlf.
# Prevents the "400 EOL warnings" churn after running prettier/format tools on Windows.
* text=auto eol=lf

# Binary files — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.webm binary
*.mov binary
